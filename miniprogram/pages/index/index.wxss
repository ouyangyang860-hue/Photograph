.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #0a0e27 0%, #1a1a4e 50%, #0a0e27 100%);
}

.star-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 60rpx;
}

.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.brand-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: float 3s ease-in-out infinite;
}

.brand-title {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.brand-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
}

.planet-area {
  margin-bottom: 80rpx;
}

.mini-planet {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.planet-body {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #4a7dff, #1a3a8a, #0a1a4a);
  box-shadow: inset -8rpx -8rpx 20rpx rgba(0, 0, 0, 0.4), 0 0 40rpx rgba(74, 125, 255, 0.3);
  animation: planetRotate 8s linear infinite;
}

.planet-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotateX(70deg);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(100, 180, 255, 0.3);
  animation: ringRotate 12s linear infinite;
}

.planet-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74, 125, 255, 0.2), transparent 70%);
  animation: glowPulse 2s ease-in-out infinite;
}

.enter-area {
  margin-bottom: 60rpx;
}

.enter-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 80rpx;
  background: linear-gradient(135deg, #4a7dff, #6c5ce7);
  border-radius: 60rpx;
  overflow: visible;
}

.enter-btn-pulse {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #4a7dff, #6c5ce7);
  animation: pulse 2s ease-in-out infinite;
  z-index: -1;
}

.enter-btn-pulse-delay {
  animation-delay: 1s;
  opacity: 0.6;
}

.enter-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.bottom-info {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.photo-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 2rpx;
}

@keyframes planetRotate {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

@keyframes ringRotate {
  from { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(0deg); }
  to { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(360deg); }
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
}