<view class="page">
  <canvas canvas-id="starCanvas" class="star-canvas" disable-scroll></canvas>

  <view class="content">
    <view class="brand-area" animation="{{brandAnimation}}">
      <view class="brand-icon">✨</view>
      <view class="brand-title text-glow">记忆星球</view>
      <view class="brand-subtitle">属于你们的专属相册</view>
    </view>

    <view class="planet-area" animation="{{planetAnimation}}">
      <view class="mini-planet">
        <view class="planet-ring"></view>
        <view class="planet-body"></view>
        <view class="planet-glow"></view>
      </view>
    </view>

    <view class="enter-area" animation="{{enterAnimation}}">
      <view class="enter-btn" bindtap="enterAlbum">
        <view class="enter-btn-pulse"></view>
        <view class="enter-btn-pulse enter-btn-pulse-delay"></view>
        <text class="enter-btn-text">🌍 进入记忆星球</text>
      </view>
    </view>

    <view class="bottom-info" animation="{{bottomAnimation}}">
      <text class="photo-count" wx:if="{{photoCount > 0}}">已有 {{photoCount}} 张记忆</text>
      <text class="photo-count" wx:else>开始你的记忆之旅</text>
    </view>
  </view>
</view>