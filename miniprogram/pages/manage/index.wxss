.page {
  min-height: 100vh;
  background: #0a0e27;
  padding-bottom: 120rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 40rpx 30rpx;
}

.top-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.nav-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.filter-tabs {
  display: flex;
  padding: 0 40rpx 30rpx;
  gap: 20rpx;
}

.tab {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 30rpx;
}

.tab-active {
  color: #ffffff;
  background: rgba(74, 125, 255, 0.3);
  border: 1rpx solid rgba(74, 125, 255, 0.5);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 12rpx;
}

.photo-item {
  position: relative;
  width: calc(33.33% - 8rpx);
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-thumb {
  width: 100%;
  height: 100%;
}

.photo-featured {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 24rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.photo-check {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: #4a7dff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx dashed rgba(255, 255, 255, 0.2);
}

.add-icon {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.3);
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-top: 8rpx;
}

.upload-progress {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 100;
  background: rgba(10, 14, 39, 0.95);
  padding: 50rpx 60rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.progress-bar {
  width: 300rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4a7dff, #6c5ce7);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx 60rpx;
  background: rgba(10, 14, 39, 0.95);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.bar-info {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.bar-actions {
  display: flex;
  gap: 16rpx;
}

.bar-btn {
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(74, 125, 255, 0.3);
  border-radius: 30rpx;
}

.bar-btn-danger {
  background: rgba(255, 80, 80, 0.3);
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #4a7dff, #6c5ce7);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #ffffff;
}