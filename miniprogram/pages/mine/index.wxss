.page {
  min-height: 100vh;
  background: #0a0e27;
  padding-bottom: 60rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 40rpx;
}

.avatar-area {
  position: relative;
  margin-bottom: 24rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(74, 125, 255, 0.5);
}

.avatar-glow {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74, 125, 255, 0.2), transparent 70%);
  z-index: -1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.join-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 30rpx 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a7dff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}

.section {
  margin: 20rpx 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.layout-options {
  display: flex;
  gap: 20rpx;
}

.layout-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}

.layout-active {
  border-color: #4a7dff;
  background: rgba(74, 125, 255, 0.15);
}

.layout-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.layout-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.theme-options {
  display: flex;
  gap: 20rpx;
}

.theme-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}

.theme-active {
  border-color: #4a7dff;
  background: rgba(74, 125, 255, 0.15);
}

.theme-color {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.theme-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
}

.footer {
  text-align: center;
  margin-top: 60rpx;
}

.version {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}