.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #0a0e27;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.blur-bg {
  position: absolute;
  top: -40rpx;
  left: -40rpx;
  right: -40rpx;
  bottom: -40rpx;
  background-size: cover;
  background-position: center;
  filter: blur(40rpx);
  opacity: 0.4;
  z-index: 0;
}

.photo-container {
  position: relative;
  z-index: 1;
  width: 90%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-main {
  width: 100%;
  max-height: 70vh;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
}

.photo-info {
  position: relative;
  z-index: 1;
  width: 85%;
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.info-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.info-featured {
  font-size: 24rpx;
  color: #ffd700;
  background: rgba(255, 215, 0, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.info-index {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.nav-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-radius: 50%;
}

.nav-arrow.left {
  left: 30rpx;
}

.nav-arrow.right {
  right: 30rpx;
}

.arrow-icon {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

.close-btn {
  position: absolute;
  top: 80rpx;
  right: 30rpx;
  z-index: 2;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-radius: 50%;
}

.close-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}